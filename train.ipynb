import os, math, torch
import torchvision
import matplotlib.pyplot as plt
import torch.nn as nn
import torch.nn.functional as F
import torch.optim as optim
from torch.utils.data import Dataset, DataLoader
from torchvision import transforms
from torchvision.models import vgg19
from PIL import Image

DEVICE = "cuda" if torch.cuda.is_available() else "cpu"

DATASET_ROOT = "/kaggle/input/gopro-large" 

IMG_SIZE = 256
BATCH_SIZE = 4
EPOCHS = 100
LAMBDA_CONTENT = 1

# Kaggle Output Directories
SAVE_DIR = "/kaggle/working/gan_checkpoints"
SAMPLE_DIR = "/kaggle/working/samples"
os.makedirs(SAVE_DIR, exist_ok=True)
os.makedirs(SAMPLE_DIR, exist_ok=True)

print(f"Using device: {DEVICE}")

class GoProDataset(Dataset):
    def __init__(self, root, mode):
        self.samples = []
        tf = transforms.Compose([
            transforms.Resize((IMG_SIZE, IMG_SIZE)),
            transforms.ToTensor(),
            transforms.Normalize((0.5, 0.5, 0.5), (0.5, 0.5, 0.5))
        ])
        
        base = os.path.join(root, mode)
        if not os.path.exists(base):
            print(f"Warning: Path {base} not found. Checking for nested structures...")
            base = os.path.join(root, os.listdir(root)[0], mode)

        for scene in os.listdir(base):
            bdir = os.path.join(base, scene, "blur")
            sdir = os.path.join(base, scene, "sharp")
            if not os.path.exists(bdir): continue
            for img in os.listdir(bdir):
                self.samples.append((os.path.join(bdir, img), 
                                     os.path.join(sdir, img)))
        self.tf = tf

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, i):
        b, s = self.samples[i]
        return self.tf(Image.open(b).convert("RGB")), \
               self.tf(Image.open(s).convert("RGB"))

class SwitchNorm2d(nn.Module):
    def __init__(self, c, eps=1e-5):
        super().__init__()
        self.eps = eps
        self.w = nn.Parameter(torch.ones(3))
        self.gamma = nn.Parameter(torch.ones(1,c,1,1))
        self.beta  = nn.Parameter(torch.zeros(1,c,1,1))
    def forward(self,x):
        mean_in = x.mean((2,3), keepdim=True)
        var_in  = x.var((2,3), keepdim=True, unbiased=False)
        mean_ln = x.mean((1,2,3), keepdim=True).expand_as(mean_in)
        var_ln  = x.var((1,2,3), keepdim=True, unbiased=False).expand_as(var_in)
        mean_bn = x.mean((0,2,3), keepdim=True)
        var_bn  = x.var((0,2,3), keepdim=True, unbiased=False)
        w = torch.softmax(self.w,0)
        mean = w[0]*mean_in + w[1]*mean_ln + w[2]*mean_bn
        var  = w[0]*var_in  + w[1]*var_ln  + w[2]*var_bn
        x = (x-mean)/torch.sqrt(var+self.eps)
        return x*self.gamma + self.beta

class ChannelAttention(nn.Module):
    def __init__(self,c):
        super().__init__()
        self.avg = nn.AdaptiveAvgPool2d(1)
        self.fc = nn.Sequential(nn.Linear(c,c//16), nn.ReLU(), nn.Linear(c//16,c), nn.Sigmoid())
    def forward(self,x):
        b,c,_,_ = x.size()
        y = self.fc(self.avg(x).view(b,c)).view(b,c,1,1)
        return x*y

class SpatialAttention(nn.Module):
    def __init__(self):
        super().__init__()
        self.conv = nn.Conv2d(2,1,7,padding=3)
    def forward(self,x):
        avg = torch.mean(x,1,keepdim=True)
        mx,_ = torch.max(x,1,keepdim=True)
        return torch.sigmoid(self.conv(torch.cat([avg,mx],1)))

class DepthWiseCNN(nn.Module):
    def __init__(self,c):
        super().__init__()
        self.dw = nn.Conv2d(c,c,3,1,1,groups=c)
        self.pw = nn.Conv2d(c,c,1)
    def forward(self,x): return self.pw(self.dw(x))

class HARBlock(nn.Module):
    def __init__(self, c):
        super().__init__()
        self.sn1, self.sn2 = SwitchNorm2d(c), SwitchNorm2d(c)
        self.c1, self.c2 = nn.Conv2d(c, c, 3, 1, 1), nn.Conv2d(c, c, 3, 1, 1)
        self.ca, self.sa = ChannelAttention(c), SpatialAttention()
        self.dw = DepthWiseCNN(c)
    def forward(self, x):
        res = x
        x = self.c1(F.relu(self.sn1(x)))
        x = self.c2(F.relu(self.sn2(x)))
        x = (self.ca(x) * self.sa(x))
        x = self.dw(x)
        return x + res

class Generator(nn.Module):
    def __init__(self):
        super().__init__()
        self.mfe = nn.ModuleList([
            nn.Conv2d(3,16,1), nn.Conv2d(3,16,3,1,1),
            nn.Conv2d(3,16,5,1,2), nn.Conv2d(3,16,7,1,3)
        ])
        self.down1 = nn.Conv2d(64,128,3,2,1)
        self.down2 = nn.Conv2d(128,256,3,2,1)
        self.har = nn.Sequential(*[HARBlock(256) for _ in range(2)])
        self.up1 = nn.ConvTranspose2d(256,128,4,2,1)
        self.up2 = nn.ConvTranspose2d(128,64,4,2,1)
        self.out = nn.Conv2d(64,3,3,1,1)

    def forward(self,x):
        x = torch.cat([m(x) for m in self.mfe], 1)
        x = self.down2(self.down1(x))
        x = self.har(x)
        x = self.up2(self.up1(x))
        return torch.tanh(self.out(x))

class Discriminator(nn.Module):
    def __init__(self):
        super().__init__()
        def blk(a, b, s=2):
            return nn.Sequential(nn.Conv2d(a, b, 4, s, 1), nn.LeakyReLU(0.2, True))
        self.net = nn.Sequential(blk(3,64), blk(64,128), blk(128,256), blk(256,512,1), nn.Conv2d(512,1,4,1,1))
    def forward(self, x): return self.net(x)


class PerceptualLoss(nn.Module):
    def __init__(self):
        super().__init__()
        vgg = vgg19(weights='DEFAULT').features
        # Move the VGG model to GPU immediately
        self.vgg = nn.Sequential(*list(vgg.children())[:35]).eval().to(DEVICE)
        
        for p in self.vgg.parameters(): 
            p.requires_grad = False
            
        self.register_buffer("mean", torch.tensor([0.485, 0.456, 0.406]).view(1, 3, 1, 1).to(DEVICE))
        self.register_buffer("std", torch.tensor([0.229, 0.224, 0.225]).view(1, 3, 1, 1).to(DEVICE))

    def forward(self, fake, real):
        fake = ((fake + 1) / 2 - self.mean) / self.std
        real = ((real + 1) / 2 - self.mean) / self.std
        return F.mse_loss(self.vgg(fake), self.vgg(real))

def compute_gradient_penalty(D, real, fake):
    alpha = torch.rand(real.size(0), 1, 1, 1).to(DEVICE)
    interp = (alpha * real + (1 - alpha) * fake).requires_grad_(True)
    d_interp = D(interp)
    grad = torch.autograd.grad(outputs=d_interp, inputs=interp, 
                               grad_outputs=torch.ones_like(d_interp),
                               create_graph=True, retain_graph=True)[0]
    return ((grad.view(grad.size(0), -1).norm(2, 1) - 1) ** 2).mean()

generator = Generator().to(DEVICE)
discriminator = Discriminator().to(DEVICE)

train_dataset = GoProDataset(root=DATASET_ROOT, mode="train")
dataloader = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True, num_workers=2, pin_memory=True)

optimizer_G = optim.Adam(generator.parameters(), lr=1e-4, betas=(0.0, 0.9))
optimizer_D = optim.Adam(discriminator.parameters(), lr=1e-5, betas=(0.0, 0.9))
perceptual_loss = PerceptualLoss()

N_CRITIC = 5
LAMBDA_GP = 10
LAMBDA_CONTENT = 0.01
perceptual_loss = PerceptualLoss()
best_g_loss = float("inf")
d_loss_history = []
g_loss_history = []
adv_loss_history = []
content_loss_history = []

for epoch in range(EPOCHS):
    for i, (blur_img, sharp_img) in enumerate(dataloader):
        blur_img, sharp_img = blur_img.to(DEVICE), sharp_img.to(DEVICE)

        for _ in range(N_CRITIC):
            optimizer_D.zero_grad()
            fake_img = generator(blur_img).detach()

            real_score = discriminator(sharp_img)
            fake_score = discriminator(fake_img)

            gp = compute_gradient_penalty(discriminator, sharp_img, fake_img)
            loss_D = fake_score.mean() - real_score.mean() + LAMBDA_GP * gp

            loss_D.backward()
            optimizer_D.step()

        if i % N_CRITIC == 0:
            optimizer_G.zero_grad()

            gen_img = generator(blur_img)
            adv_loss = -torch.mean(discriminator(gen_img))
            content_loss = perceptual_loss(gen_img, sharp_img)

            loss_G = adv_loss + (LAMBDA_CONTENT * content_loss)

            loss_G.backward()
            optimizer_G.step()

        if i % 50 == 0 and i % N_CRITIC == 0:
            d_loss_history.append(loss_D.item())
            g_loss_history.append(loss_G.item())
            adv_loss_history.append(adv_loss.item())
            content_loss_history.append(content_loss.item())
            print(f"Epoch [{epoch}/{EPOCHS}] Batch {i} | "f"D: {loss_D.item():.4f} | "f"G: {loss_G.item():.4f} | "f"Adv: {adv_loss.item():.4f} | "f"Perc: {content_loss.item():.4f}")
        # ---------------- SAVE SAMPLE IMAGE (Kaggle Path) ----------------
        if i % 200 == 0 and i % N_CRITIC == 0:
            # Saving to /kaggle/working/ so you can see them in the Output tab
            torchvision.utils.save_image(gen_img, f"{SAVE_DIR}/out_{epoch}_{i}.png", normalize=True)

    checkpoint = {
        "epoch": epoch,
        "generator": generator.state_dict(),
        "discriminator": discriminator.state_dict(),
        "optimizer_G": optimizer_G.state_dict(),
        "optimizer_D": optimizer_D.state_dict(),
        "g_loss": loss_G.item()
    }

    torch.save(checkpoint, f"{SAVE_DIR}/last_checkpoint.pth")
    if loss_G.item() < best_g_loss:
        best_g_loss = loss_G.item()
        torch.save(generator.state_dict(), f"{SAVE_DIR}/best_generator.pth")
        print("Best generator saved")

    print(f"Checkpoint saved for epoch {epoch}")


# Generator Total Loss
plt.figure(figsize=(8,5))
plt.plot(g_loss_history, label="Generator Total Loss")
plt.title("Generator Loss")
plt.xlabel("Epochs")
plt.ylabel("Loss")
plt.legend()
plt.show()

# Adversarial Loss
plt.figure(figsize=(8,5))
plt.plot(adv_loss_history, label="Adversarial Loss")
plt.title("Adversarial Loss")
plt.xlabel("Epochs")
plt.ylabel("Loss")
plt.legend()
plt.show()

# Perceptual Loss
plt.figure(figsize=(8,5))
plt.plot(content_loss_history, label="Perceptual Loss")
plt.title("Perceptual Loss")
plt.xlabel("Epochs")
plt.ylabel("Loss")
plt.legend()
plt.show()

# Discriminator Loss
plt.figure(figsize=(8,5))
plt.plot(d_loss_history, label="Discriminator Loss")
plt.title("Discriminator Loss")
plt.xlabel("Epochs")
plt.ylabel("Loss")
plt.legend()
plt.show()
