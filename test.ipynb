import os, torch, math
import torchvision
import torch.nn as nn
import torch.nn.functional as F
from torch.utils.data import Dataset, DataLoader
from torchvision import transforms
from PIL import Image
from skimage.metrics import structural_similarity as ssim
import numpy as np

DEVICE = "cuda" if torch.cuda.is_available() else "cpu"

# ---------------- PATHS ----------------
# Adjusted to match the dataset structure and your training output
DATASET_ROOT = "/kaggle/input/gopro-large/GOPRO_Large"
MODEL_PATH = "/kaggle/working/gan_checkpoints/best_generator.pth"
SAVE_DIR = "/kaggle/working/test_results"
os.makedirs(SAVE_DIR, exist_ok=True)

IMG_SIZE = 256
BATCH_SIZE = 1  

# ---------------- MODEL ARCHITECTURE (SYNCED WITH TRAINING) ----------------

class SwitchNorm2d(nn.Module):
    def __init__(self, c, eps=1e-5):
        super().__init__()
        self.eps = eps
        self.w = nn.Parameter(torch.ones(3))
        self.gamma = nn.Parameter(torch.ones(1,c,1,1))
        self.beta  = nn.Parameter(torch.zeros(1,c,1,1))
    def forward(self,x):
        mean_in = x.mean((2,3), keepdim=True)
        var_in  = x.var((2,3), keepdim=True, unbiased=False)
        mean_ln = x.mean((1,2,3), keepdim=True).expand_as(mean_in)
        var_ln  = x.var((1,2,3), keepdim=True, unbiased=False).expand_as(var_in)
        mean_bn = x.mean((0,2,3), keepdim=True)
        var_bn  = x.var((0,2,3), keepdim=True, unbiased=False)
        w = torch.softmax(self.w,0)
        mean = w[0]*mean_in + w[1]*mean_ln + w[2]*mean_bn
        var  = w[0]*var_in  + w[1]*var_ln  + w[2]*var_bn
        x = (x-mean)/torch.sqrt(var+self.eps)
        return x*self.gamma + self.beta

class DepthWiseCNN(nn.Module):
    def __init__(self,c):
        super().__init__()
        self.dw = nn.Conv2d(c,c,3,1,1,groups=c)
        self.pw = nn.Conv2d(c,c,1)
    def forward(self,x): return self.pw(self.dw(x))

class TripleAttention(nn.Module):
    def __init__(self):
        super(TripleAttention, self).__init__()
        self.height_gate = nn.Sequential(nn.Conv2d(2, 1, 7, padding=3), nn.Sigmoid())
        self.width_gate = nn.Sequential(nn.Conv2d(2, 1, 7, padding=3), nn.Sigmoid())
        self.spatial_gate = nn.Sequential(nn.Conv2d(2, 1, 7, padding=3), nn.Sigmoid())

    def forward(self, x):
        # 1. Channel + Height Attention
        x_h = x.permute(0, 3, 1, 2) # (B, W, C, H)
        # Use keepdim=True so we don't need to unsqueeze manually
        avg_h = torch.mean(x_h, dim=1, keepdim=True)
        max_h, _ = torch.max(x_h, dim=1, keepdim=True)
        x_h_at = self.height_gate(torch.cat([avg_h, max_h], dim=1))
        out_h = (x_h * x_h_at).permute(0, 2, 3, 1)

        # 2. Channel + Width Attention
        x_w = x.permute(0, 2, 1, 3) # (B, H, C, W)
        avg_w = torch.mean(x_w, dim=1, keepdim=True)
        max_w, _ = torch.max(x_w, dim=1, keepdim=True)
        x_w_at = self.width_gate(torch.cat([avg_w, max_w], dim=1))
        out_w = (x_w * x_w_at).permute(0, 2, 1, 3)

        # 3. Standard Spatial Attention
        avg_s = torch.mean(x, dim=1, keepdim=True)
        max_s, _ = torch.max(x, dim=1, keepdim=True)
        x_s_at = self.spatial_gate(torch.cat([avg_s, max_s], dim=1))
        out_s = x * x_s_at

        return (out_h + out_w + out_s) / 3

class HARBlock(nn.Module):
    def __init__(self, c):
        super().__init__()
        self.sn1, self.sn2 = SwitchNorm2d(c), SwitchNorm2d(c)
        self.c1, self.c2 = nn.Conv2d(c, c, 3, 1, 1), nn.Conv2d(c, c, 3, 1, 1)
        self.tam = TripleAttention() 
        self.dw = DepthWiseCNN(c)
    def forward(self, x):
        res = x
        x = self.c1(F.relu(self.sn1(x)))
        x = self.c2(F.relu(self.sn2(x)))
        x = self.tam(x)
        x = self.dw(x)
        return x + res

class Generator(nn.Module):
    def __init__(self):
        super().__init__()
        self.mfe = nn.ModuleList([
            nn.Conv2d(3,16,1), nn.Conv2d(3,16,3,1,1),
            nn.Conv2d(3,16,5,1,2), nn.Conv2d(3,16,7,1,3)
        ])
        self.down1 = nn.Conv2d(64,128,3,2,1)
        self.down2 = nn.Conv2d(128,256,3,2,1)
        self.har = nn.Sequential(*[HARBlock(256) for _ in range(9)]) # Synced to 9 blocks
        self.up1 = nn.ConvTranspose2d(256,128,4,2,1)
        self.up2 = nn.ConvTranspose2d(128,64,4,2,1)
        self.out = nn.Conv2d(64,3,3,1,1)

    def forward(self, x):
        initial_input = x 
        x = torch.cat([m(x) for m in self.mfe], 1)
        x = self.down2(self.down1(x))
        x = self.har(x)
        x = self.up2(self.up1(x))
        residual_blur_map = self.out(x)
        final_output = initial_input + residual_blur_map # Global Skip Connection
        return torch.tanh(final_output)

# ---------------- DATASET ----------------

class GoProDataset(Dataset):
    def __init__(self, root, mode):
        self.samples = []
        self.tf = transforms.Compose([
            transforms.Resize((IMG_SIZE, IMG_SIZE)),
            transforms.ToTensor(),
            transforms.Normalize((0.5,0.5,0.5),(0.5,0.5,0.5))
        ])
        base = os.path.join(root, mode)
        # Handle nested folder structure if present
        if not os.path.exists(base):
            subdirs = [d for d in os.listdir(root) if os.path.isdir(os.path.join(root, d))]
            if subdirs: base = os.path.join(root, subdirs[0], mode)

        for scene in os.listdir(base):
            bdir, sdir = os.path.join(base, scene, "blur"), os.path.join(base, scene, "sharp")
            if not os.path.exists(bdir): continue
            for img in os.listdir(bdir):
                self.samples.append((os.path.join(bdir, img), os.path.join(sdir, img)))

    def __len__(self): return len(self.samples)
    def __getitem__(self, i):
        b, s = self.samples[i]
        return self.tf(Image.open(b).convert("RGB")), self.tf(Image.open(s).convert("RGB"))

# ---------------- METRICS & UTILS ----------------

def calc_psnr(fake, real):
    mse = F.mse_loss(fake, real)
    return 20 * torch.log10(2.0 / torch.sqrt(mse))

def calc_ssim(fake, real):
    # Convert to HWC and [0, 1] range for skimage
    f = (fake.squeeze(0).permute(1, 2, 0).cpu().numpy() * 0.5 + 0.5).clip(0, 1)
    r = (real.squeeze(0).permute(1, 2, 0).cpu().numpy() * 0.5 + 0.5).clip(0, 1)
    return ssim(f, r, data_range=1.0, channel_axis=-1)

# ---------------- EXECUTION ----------------

print(f"Loading model from {MODEL_PATH}...")
generator = Generator().to(DEVICE)
generator.load_state_dict(torch.load(MODEL_PATH, map_location=DEVICE))
generator.eval()

test_dataset = GoProDataset(DATASET_ROOT, "test")
test_loader = DataLoader(test_dataset, batch_size=1, shuffle=False)

results_list = []
print(f"Starting evaluation on {len(test_dataset)} images...")

with torch.no_grad():
    for i, (blur, sharp) in enumerate(test_loader):
        blur, sharp = blur.to(DEVICE), sharp.to(DEVICE)
        fake = generator(blur)

        p_val = calc_psnr(fake, sharp).item()
        s_val = calc_ssim(fake, sharp)

        results_list.append({'psnr': p_val, 'ssim': s_val, 'blur': blur.cpu(), 'fake': fake.cpu(), 'sharp': sharp.cpu()})
        
        if i % 100 == 0:
            print(f"Processed {i}/{len(test_dataset)}...")

# Final Stats
avg_psnr = sum(r['psnr'] for r in results_list) / len(results_list)
avg_ssim = sum(r['ssim'] for r in results_list) / len(results_list)

print("\n================ FINAL RESULTS ================")
print(f"Average PSNR: {avg_psnr:.2f} dB")
print(f"Average SSIM: {avg_ssim:.4f}")
print("===============================================\n")

# Save Top 10 Visual Results
top_10 = sorted(results_list, key=lambda x: x['psnr'], reverse=True)[:10]
for idx, res in enumerate(top_10):
    b = (res['blur'] * 0.5 + 0.5).clamp(0, 1)
    f = (res['fake'] * 0.5 + 0.5).clamp(0, 1)
    s = (res['sharp'] * 0.5 + 0.5).clamp(0, 1)
    
    grid = torch.cat([b, f, s], dim=3)
    torchvision.utils.save_image(grid, f"{SAVE_DIR}/rank_{idx+1}_psnr_{res['psnr']:.2f}.png")

print(f"Visual comparisons saved to {SAVE_DIR}")
